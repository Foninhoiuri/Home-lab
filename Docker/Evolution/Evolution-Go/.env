# ==========================================
# CONFIGURAÇÕES DA EVOLUTION API
# ==========================================
# O IP do seu servidor onde a API ficará acessível
SERVER_URL=http://192.168.1.200:8080

# Crie uma senha forte. Você usará isso no n8n para parear com a API.
API_KEY=sua_senha_super_secreta_aqui

# Fuso horário para os registros de mensagens
TIMEZONE=America/Sao_Paulo

# ==========================================
# CREDENCIAIS DO BANCO DE DADOS
# ==========================================
DB_USER=evo_user
DB_PASS=senha_banco_evo
DB_NAME=evolution_db